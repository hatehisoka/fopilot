# --- Database ---
POSTGRES_USER=fopilot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fopilot
# Дефолти для локального запуску (бекенд на хості проти контейнерного Postgres).
# Контейнер пробрасується на 5433 (див. docker-compose.yml), щоб не конфліктувати
# з локально встановленим Postgres на 5432.
# Усередині docker compose бекенд перевизначає ці значення на db:5432.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Повний DSN збирається з полів вище у app/config.py; за потреби можна перевизначити:
# DATABASE_URL=postgresql+psycopg://fopilot:change_me@localhost:5433/fopilot

# --- Business config ---
# Річний ліміт єдиного податку (3 група, 2026). Не хардкодиться в коді.
EP_ANNUAL_LIMIT=10091049
# Мінімум днів від початку року, щоб довіряти run-rate прогнозу (інакше "недостатньо даних").
EP_FORECAST_MIN_DAYS=30
# Денна ємність (годин) — знаменник utilization.
WORK_HOURS_PER_DAY=8

# --- External APIs ---
NBU_RATE_URL=https://bank.gov.ua/NBUStatService/v1/statdirectory/exchange

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
